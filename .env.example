# Motion MCP Configuration
# Follow the setup guide: https://github.com/lorecraft-io/motion-mcp#setup

# Get your Motion API key from: Motion Settings > API
MOTION_API_KEY=your_motion_api_key_here

# Firebase credentials (needed for calendar access)
# See README for how to extract these from your browser
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_REFRESH_TOKEN=your_firebase_refresh_token_here

# Your Motion user ID (found in browser DevTools)
MOTION_USER_ID=your_user_id_here

# Timezone (defaults to America/New_York if not set)
MOTION_TIMEZONE=America/New_York
